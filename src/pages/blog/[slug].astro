---
import Layout from "../../layouts/Layout.astro";
import Footer from "../../components/Footer.astro";
import { getCollection } from "astro:content";
import { filterBlogPosts } from "../../utils/blog";

export async function getStaticPaths() {
  const allPosts = await getCollection("blog");
  const posts = filterBlogPosts(allPosts);
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post, showBlog: posts.length > 0 },
  }));
}

const { post, showBlog } = Astro.props;
const { Content } = await post.render();

const formattedDate = new Intl.DateTimeFormat("en-US", {
  year: "numeric",
  month: "long",
  day: "numeric",
}).format(post.data.pubDate);

// Use post.id which contains the full path (e.g., "example-post.md" or "example-with-assets/index.md")
const sourceUrl = `https://github.com/kahlstrm/web/blob/main/src/content/blog/${post.id}`;

// Structured data for SEO
const structuredData = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  headline: post.data.title,
  description: post.data.description,
  author: {
    "@type": "Person",
    name: post.data.author,
    url: `https://github.com/${post.data.author}`,
  },
  datePublished: post.data.pubDate.toISOString(),
  url: `https://kahlstrm.xyz/blog/${post.slug}`,
};
---

<Layout
  title={`${post.data.title} - Kalle Ahlström`}
  description={post.data.description}
  type="article"
  publishedTime={post.data.pubDate.toISOString()}
  author={post.data.author}
  showBlog={showBlog}
>
  <main>
    <article>
      <header>
        <h1 transition:name={`post-title-${post.slug}`}>{post.data.title}</h1>
        <div class="meta">
          <time
            datetime={post.data.pubDate.toISOString()}
            transition:name={`post-date-${post.slug}`}>{formattedDate}</time
          >
          <span class="author"
            >by <a
              href={`https://github.com/${post.data.author}`}
              target="_blank"
              rel="noopener noreferrer">@{post.data.author}</a
            ></span
          >
        </div>
      </header>

      <div class="content">
        <Content />
      </div>
    </article>

    <!-- Structured Data for SEO -->
    <script
      is:inline
      type="application/ld+json"
      set:html={JSON.stringify(structuredData)}
    />
  </main>
  <Footer slot="footer" sourceUrl={sourceUrl} />
</Layout>

<style>
  main {
    flex: 1;
    display: flex;
    flex-direction: column;
  }

  article {
    padding: 1rem 0;
    flex: 1;
  }

  header {
    margin-bottom: 2rem;
    padding-bottom: 1.5rem;
    border-bottom: 2px solid var(--color-border);
  }

  h1 {
    margin: 0 0 1rem 0;
    font-size: 2.5rem;
    line-height: 1.2;
  }

  .meta {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
    font-size: 0.95rem;
  }

  time {
    font-style: italic;
  }

  .content {
    line-height: 1.8;
  }

  /* Markdown content styles */
  .content :global(h2) {
    margin-top: 2.5rem;
    margin-bottom: 1rem;
    font-size: 1.8rem;
  }

  .content :global(h3) {
    margin-top: 2rem;
    margin-bottom: 0.75rem;
    font-size: 1.4rem;
  }

  .content :global(p) {
    margin-bottom: 1.25rem;
  }

  .content :global(ul),
  .content :global(ol) {
    margin-bottom: 1.25rem;
    padding-left: 2rem;
  }

  .content :global(li) {
    margin-bottom: 0.5rem;
  }

  .content :global(a) {
    color: #4f39fa;
    text-decoration: underline;
  }

  .content :global(code) {
    font-family: "Courier New", Courier, monospace;
    font-size: 0.9em;
    padding: 0.2em 0.4em;
    background: rgba(0, 0, 0, 0.05);
    border-radius: 3px;
  }

  .content :global(pre) {
    margin: 1.5rem 0;
    padding: 1rem;
    border-radius: 0.5rem;
    overflow-x: auto;
    line-height: 1.5;
  }

  .content :global(pre code) {
    background: none;
    padding: 0;
    font-size: 0.875rem;
  }

  .content :global(blockquote) {
    margin: 1.5rem 0;
    padding-left: 1.5rem;
    border-left: 4px solid #4f39fa;
    font-style: italic;
  }

  .content :global(.blog-image-lightbox) {
    margin: 1.5rem 0;
  }

  .content :global(.blog-image-lightbox__trigger) {
    display: block;
    width: 100%;
    padding: 0;
    border: none;
    background: none;
    border-radius: 0.5rem;
    overflow: hidden;
    cursor: zoom-in;
  }

  .content :global(.blog-image-lightbox__trigger:focus-visible) {
    outline: 3px solid #4f39fa;
    outline-offset: 4px;
  }

  .content :global(.blog-image-lightbox__image) {
    display: block;
    width: 100%;
    height: auto;
    margin: 0;
    border-radius: 0.5rem;
    transition: transform 180ms ease;
  }

  .content
    :global(.blog-image-lightbox__trigger:hover .blog-image-lightbox__image),
  .content
    :global(
      .blog-image-lightbox__trigger:focus-visible .blog-image-lightbox__image
    ) {
    transform: scale(1.012);
  }

  .content :global(.blog-image-lightbox__popover) {
    width: fit-content;
    max-width: min(96vw, 70rem);
    max-height: 90vh;
    margin: auto;
    padding: clamp(0.75rem, 1.5vw, 1rem);
    border: 1px solid color-mix(in hsl, var(--color-border), #000 20%);
    border-radius: 0.8rem;
    background: hsl(44 48% 96% / 0.98);
    color: var(--color-text);
    opacity: 0;
    transform: translateY(0.75rem) scale(0.98);
    transition:
      opacity 220ms ease,
      transform 220ms ease,
      display 220ms ease allow-discrete,
      overlay 220ms ease allow-discrete;
  }

  .content :global(.blog-image-lightbox__popover:popover-open) {
    display: grid;
    gap: 0.75rem;
    opacity: 1;
    transform: translateY(0) scale(1);
  }

  @starting-style {
    .content :global(.blog-image-lightbox__popover:popover-open) {
      opacity: 0;
      transform: translateY(0.75rem) scale(0.98);
    }
  }

  .content :global(.blog-image-lightbox__popover::backdrop) {
    background: hsl(0 0% 0% / 0);
    backdrop-filter: blur(0);
    transition:
      background-color 220ms ease,
      backdrop-filter 220ms ease,
      display 220ms ease allow-discrete,
      overlay 220ms ease allow-discrete;
  }

  .content :global(.blog-image-lightbox__popover:popover-open::backdrop) {
    background: hsl(0 0% 6% / 0.6);
    backdrop-filter: blur(2px);
  }

  @starting-style {
    .content :global(.blog-image-lightbox__popover:popover-open::backdrop) {
      background: hsl(0 0% 0% / 0);
      backdrop-filter: blur(0);
    }
  }

  .content :global(.blog-image-lightbox__close) {
    justify-self: end;
    border: 1px solid color-mix(in hsl, var(--color-border), #000 20%);
    border-radius: 999px;
    background: hsl(42 52% 88%);
    color: var(--color-text);
    font: inherit;
    font-size: 0.9rem;
    font-weight: 600;
    padding: 0.35rem 0.85rem;
    cursor: pointer;
  }

  .content :global(.blog-image-lightbox__close:focus-visible) {
    outline: 3px solid #4f39fa;
    outline-offset: 2px;
  }

  .content :global(.blog-image-lightbox__media) {
    display: grid;
    place-items: center;
  }

  .content :global(.blog-image-lightbox__popover-image) {
    display: block;
    width: auto;
    height: auto;
    max-width: min(92vw, 70rem);
    max-height: calc(90vh - 6rem);
    margin: 0;
    border-radius: 0.5rem;
  }

  .content :global(.blog-image-lightbox__caption) {
    margin: 0;
    text-align: center;
    font-size: 0.9rem;
    line-height: 1.4;
    color: color-mix(in hsl, var(--color-text), white 18%);
  }

  .content
    :global(
      img:not(.blog-image-lightbox__image):not(
          .blog-image-lightbox__popover-image
        )
    ) {
    max-width: 100%;
    height: auto;
    border-radius: 0.5rem;
    margin: 1.5rem 0;
  }

  .content :global(hr) {
    margin: 2rem 0;
    border: none;
    border-top: 2px solid var(--color-border);
  }

  .content :global(table) {
    width: 100%;
    border-collapse: collapse;
    margin: 1.5rem 0;
    border: 1px solid var(--color-border);
    border-radius: 0.5rem;
    overflow: hidden;
  }

  .content :global(th),
  .content :global(td) {
    padding: 0.75rem 1rem;
    border: 1px solid var(--color-border);
    text-align: left;
  }

  .content :global(th) {
    background: rgba(0, 0, 0, 0.05);
    font-weight: 600;
  }

  .content :global(tr:nth-child(even)) {
    background: rgba(0, 0, 0, 0.02);
  }

  @media (max-width: 600px) {
    h1 {
      font-size: 2rem;
    }

    .content :global(.blog-image-lightbox__popover) {
      padding: 0.75rem;
    }

    .content :global(.blog-image-lightbox__popover-image) {
      max-height: calc(90vh - 5rem);
    }

    .content :global(.blog-image-lightbox__close) {
      font-size: 0.85rem;
      padding: 0.3rem 0.75rem;
    }
  }
</style>
